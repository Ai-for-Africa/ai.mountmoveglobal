# =============================================================================
# MMG REGISTRATION PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development
# Set these as environment variables in your deployment platform (Vercel, Railway, etc.)
# NEVER commit .env.local to version control
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
# The base URL of your deployed app (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Local development example:  postgresql://USER:PASSWORD@localhost:5432/mmg_registration
# Railway example:             postgresql://postgres:XXXX@containers-us-west-XX.railway.app:XXXX/railway
# Supabase example:            postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Get from: https://dashboard.stripe.com/webhooks
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Paystack ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Examples:
#   Gmail:     host=smtp.gmail.com, port=587, secure=false (use App Password)
#   Brevo:     host=smtp-relay.brevo.com, port=587
#   Resend:    host=smtp.resend.com, port=587
#   Mailgun:   host=smtp.mailgun.org, port=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@mountmoveglobal.com

# Admin notification email — receives a copy of every successful registration
ADMIN_EMAIL=admin@mountmoveglobal.com

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# A strong random string used to authenticate admin API requests
# Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=change-this-to-a-long-random-string-in-production

# ─── Optional ────────────────────────────────────────────────────────────────
# WhatsApp number shown in confirmation emails (include country code, no spaces)
ADMIN_WHATSAPP=+2348000000000

# Node environment
NODE_ENV=development
